# ANGREN TAXI production env example.
# Copy to .env on the VPS and replace every secret before running Docker Compose.

NODE_ENV=production
POSTGRES_DB=taxi_app
POSTGRES_USER=taxi
POSTGRES_PASSWORD=generate-strong-postgres-password
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

REDIS_BIND=127.0.0.1
REDIS_PORT=6379
REDIS_URL=rediss://default:replace-with-upstash-password@replace-with-upstash-host:6379
REDIS_DRIVERS_GEO_KEY=drivers:geo
REDIS_DRIVER_STATUS_KEY_PREFIX=driver:status
REDIS_RIDE_OFFER_KEY_PREFIX=ride:offer
REDIS_RIDE_LOCK_KEY_PREFIX=ride:lock

BACKEND_PORT=3000
BACKEND_BIND=127.0.0.1
ADMIN_PORT=3001
ADMIN_BIND=127.0.0.1

BACKEND_IMAGE=taxi-app-backend
ADMIN_IMAGE=taxi-app-admin

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

JWT_SECRET=generate-at-least-32-random-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
ENABLE_DEV_LOGIN=false

# Public URLs used by browser/mobile clients.
PUBLIC_API_URL=https://api.example.com
PUBLIC_ADMIN_URL=https://admin.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
MAPBOX_ACCESS_TOKEN=sk-or-pk-replace-with-mapbox-access-token

# Temporary admin bootstrap credentials for MVP.
# Replace with seeded/admin-managed credentials before real production use.
NEXT_PUBLIC_ADMIN_PHONE=+998900000001
NEXT_PUBLIC_ADMIN_PASSWORD=generate-strong-admin-password

# Used by scripts/backup-postgres.sh.
BACKUP_DIR=/opt/taxi-app/backups/postgres
BACKUP_RETENTION_DAYS=14
