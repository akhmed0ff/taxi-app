{
  "name": "taxi-app-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ANGREN TAXI backend built with NestJS, PostgreSQL, Redis, Socket.IO and BullMQ.",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "infra:up": "docker compose -f ../docker-compose.yml up -d postgres redis",
    "redis:up": "docker compose -f ../docker-compose.yml up -d redis",
    "redis:down": "docker compose -f ../docker-compose.yml down",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "npm run test:core-flow",
    "test:env": "ts-node src/infrastructure/config/env.validation.spec.ts",
    "test:auth": "ts-node src/modules/auth/auth.service.spec.ts && ts-node src/modules/auth/auth.throttler.spec.ts",
    "test:pricing": "ts-node src/modules/pricing/pricing.service.spec.ts",
    "test:rating": "ts-node src/modules/rating/rating.service.spec.ts",
    "test:concurrent-accept": "ts-node src/modules/order/order.service.concurrent.spec.ts",
    "test:order-lifecycle": "ts-node src/modules/order/order.service.lifecycle.spec.ts",
    "test:order-history": "ts-node src/modules/order/order.service.history.spec.ts",
    "test:matching": "ts-node src/modules/matching/matching.service.spec.ts",
    "test:socket": "ts-node src/infrastructure/socket/socket.gateway.spec.ts",
    "test:core-flow": "npm run test:env && npm run test:auth && npm run test:pricing && npm run test:rating && npm run test:concurrent-accept && npm run test:order-lifecycle && npm run test:order-history && npm run test:matching && npm run test:socket",
    "check:legacy-hashes": "ts-node scripts/check-legacy-hashes.ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/client": "^6.18.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.8.1",
    "prisma": "^6.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/node": "^24.8.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
