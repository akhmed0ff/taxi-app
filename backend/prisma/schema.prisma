generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  role         String   @default("PASSENGER")
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  driverProfile Driver?
  customerRides Ride[]   @relation("CustomerRides")
  payments      Payment[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
}

model Driver {
  id        String       @id @default(cuid())
  userId    String       @unique
  status    String       @default("OFFLINE")
  rating    Float        @default(5)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  vehicle   Vehicle?
  documents DriverDocument[]
  rides     Ride[]           @relation("DriverRides")
  offers    RideOffer[]
}

model Vehicle {
  id          String   @id @default(cuid())
  driverId    String   @unique
  make        String
  model       String
  color       String
  plateNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])
}

model DriverDocument {
  id        String   @id @default(cuid())
  driverId  String
  type      String
  fileUrl   String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId])
}

model Ride {
  id             String     @id @default(cuid())
  customerId     String
  driverId       String?
  status         String     @default("CREATED")
  tariffClass    String     @default("STANDARD")
  pickupLat      Float
  pickupLng      Float
  pickupAddress  String?
  dropoffLat     Float
  dropoffLng     Float
  dropoffAddress String?
  distanceMeters Int?
  waitingMinutes Int        @default(0)
  stopMinutes    Int        @default(0)
  estimatedFare  Int?
  estimatedFareDetails Json?
  finalFare      Int?
  finalFareDetails Json?
  cancelReason   String?
  passengerRating Int?
  driverRating    Int?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer      User                @relation("CustomerRides", fields: [customerId], references: [id])
  driver        Driver?             @relation("DriverRides", fields: [driverId], references: [id])
  offers        RideOffer[]
  statusHistory RideStatusHistory[]
  payment       Payment?

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([customerId, status])
  @@index([driverId, status])
  @@index([createdAt(sort: Desc)])
}

model RideOffer {
  id             String   @id @default(cuid())
  rideId         String
  driverId       String
  status         String   @default("PENDING")
  distanceMeters Int?
  expiresAt      DateTime
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ride   Ride   @relation(fields: [rideId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([rideId, driverId])
}

model RideStatusHistory {
  id        String     @id @default(cuid())
  rideId    String
  status    String
  reason    String?
  createdAt DateTime   @default(now())

  ride Ride @relation(fields: [rideId], references: [id])

  @@index([rideId])
}

model Payment {
  id        String        @id @default(cuid())
  rideId    String        @unique
  userId    String
  amount    Int
  currency  String        @default("UZS")
  method    String        @default("CASH")
  commissionAmount Int    @default(0)
  status    String        @default("PENDING")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  ride Ride @relation(fields: [rideId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Tariff {
  id                 String   @id @default(cuid())
  city               String   @default("Angren")
  tariffClass        String
  title              String   @default("")
  sortOrder          Int      @default(0)
  etaMinutes         Int      @default(5)
  seats              Int      @default(4)
  pricePer100m       Int?
  baseFare           Int
  perKm              Int      @default(2000)
  freeWaitingMinutes Int      @default(3)
  waitingPerMinute   Int      @default(500)
  stopPerMinute      Int      @default(500)
  minimumFare        Int
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
