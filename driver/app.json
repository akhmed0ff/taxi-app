{
  "expo": {
    "name": "ANGREN TAXI Driver",
    "slug": "angren-taxi-driver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsVersion": "11.18.2"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Show current driver location on map."
        }
      ]
    ]
  }
}
