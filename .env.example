# ANGREN TAXI local development env example.
# Do not copy this file to production. Use .env.production.example on VPS.

NODE_ENV=development
POSTGRES_DB=taxi_app
POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_DRIVERS_GEO_KEY=drivers:geo
REDIS_DRIVER_STATUS_KEY_PREFIX=driver:status
REDIS_RIDE_OFFER_KEY_PREFIX=ride:offer
REDIS_RIDE_LOCK_KEY_PREFIX=ride:lock
BACKEND_PORT=3000
BACKEND_BIND=127.0.0.1
ADMIN_PORT=3001
ADMIN_BIND=127.0.0.1
BACKEND_IMAGE=taxi-app-backend
ADMIN_IMAGE=taxi-app-admin
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
ENABLE_DEV_LOGIN=true
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_TOKEN=mapbox-token-for-local-web-map
MAPBOX_ACCESS_TOKEN=mapbox-token-for-backend-directions
NEXT_PUBLIC_ADMIN_PHONE=+998900000001
NEXT_PUBLIC_ADMIN_PASSWORD=password123
